{
  "name": "tmp-companion",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "description": "USB controller for the Fender Tone Master Pro: loudness leveling, block copy, and song/setlist editing",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "bash scripts/e2e.sh",
    "lint": "eslint src/ e2e/ --max-warnings 0",
    "lint:fix": "eslint src/ e2e/ --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "screenshots": "cargo test --manifest-path src-tauri/Cargo.toml --features e2e --lib build_showcase_fixture -- --ignored && playwright test -c e2e/showcase/playwright.showcase.config.ts",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'e2e/**/*.ts' '*.config.{js,ts}' .prettierrc index.html",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'e2e/**/*.ts' '*.config.{js,ts}' .prettierrc index.html",
    "leak-guard": "bash scripts/leak-guard.sh --all",
    "prepare": "husky"
  },
  "lint-staged": {
    "{src,e2e}/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "*.{js,json,md,css,html}": "prettier --write"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.6",
    "@semantic-release/exec": "^7.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
