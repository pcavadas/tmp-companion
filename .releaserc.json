{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bash scripts/release-build.sh \"${nextRelease.version}\" \"${Buffer.from(nextRelease.notes || '').toString('base64')}\""
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "src-tauri/target/aarch64-apple-darwin/release/bundle/dmg/*.dmg",
            "name": "TMP-Companion-AppleSilicon.dmg"
          },
          {
            "path": "src-tauri/target/aarch64-apple-darwin/release/bundle/macos/*.app.tar.gz",
            "name": "TMP-Companion-AppleSilicon.app.tar.gz"
          },
          {
            "path": "src-tauri/target/aarch64-apple-darwin/release/bundle/macos/latest.json"
          }
        ]
      }
    ]
  ]
}
